# ============================================================
# Estoicismo Digital · Variables de entorno
# ============================================================
# Copia este archivo como .env.local en apps/web/ y .env en
# apps/mobile/, y rellena los valores reales.
#
# NUNCA commitees los archivos reales. Solo este .example.
# ============================================================

# ─── Supabase ────────────────────────────────────────────────
# Obtén estos valores en: Supabase Dashboard > Project Settings > API

# Web (Next.js) — los NEXT_PUBLIC_* son visibles en el cliente
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-only — webhooks, funciones admin. NUNCA expongas al cliente
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Mobile (Expo) — los EXPO_PUBLIC_* son visibles en el cliente
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Anthropic (Pegasso AI) ──────────────────────────────────
# Necesario para el chat con Pegasso. Obtén en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# ─── Twilio (WhatsApp para Pegasso) ──────────────────────────
# Opcional — solo si quieres conectar Pegasso por WhatsApp.
# Setup: https://console.twilio.com/ (crea cuenta + Sandbox)
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Stripe (Premium) ────────────────────────────────────────
# Opcional — solo si activas el upgrade a premium.
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
